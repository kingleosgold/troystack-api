# TroyStack API - Environment Variables
# Copy to .env and fill in values

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Server
PORT=3000
NODE_ENV=production

# Gemini AI (intelligence, daily briefs, advisor, receipt scanner)
GEMINI_API_KEY=your-gemini-api-key

# Intelligence generation API key (protects /v1/intelligence/generate)
INTELLIGENCE_API_KEY=your-intelligence-api-key

# Stripe billing
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_GOLD_MONTHLY_PRICE_ID=price_xxx
STRIPE_GOLD_YEARLY_PRICE_ID=price_xxx
STRIPE_GOLD_LIFETIME_PRICE_ID=price_xxx

# YouTube Data API v3 — intelligence scraper monitors precious metals channels
YOUTUBE_API_KEY=your-youtube-api-key

# X / Twitter auto-tweet (@troystack_) — posts Stack Signal articles
X_CONSUMER_KEY=your-x-consumer-key
X_CONSUMER_SECRET=your-x-consumer-secret
X_ACCESS_TOKEN=your-x-access-token
X_ACCESS_SECRET=your-x-access-secret

# Admin health endpoint — required header X-Admin-Auth-Key for /v1/admin/health/detailed
# and /v1/admin/health/:checkId. If unset, those endpoints fail-closed (401).
# Summary endpoint /v1/admin/health is always public.
ADMIN_AUTH_KEY=generate-a-random-32-char-secret

# Finance Dashboard — API credentials for nightly cost snapshot (Phase 1)
# The snapshot cron runs daily at 2:00 AM EST and writes to cost_snapshots.
# Missing creds cause the affected source to row-log as ERROR (non-fatal).

# Anthropic Admin API key (distinct from ANTHROPIC_API_KEY). Create at
# https://console.anthropic.com under Settings → Admin Keys.
ANTHROPIC_ADMIN_KEY=sk-ant-admin01-xxx

# Railway public API token. Create at https://railway.app/account/tokens
RAILWAY_API_TOKEN=xxx

# Vercel API token + team id for mancini-tech-solutions. Token at
# https://vercel.com/account/tokens; team id under Team Settings → General.
VERCEL_API_TOKEN=xxx
VERCEL_TEAM_ID=team_xxx

# Manual monthly estimates — update monthly from the vendor dashboard.
# These feed cost_snapshots as source_type='manual' rows.
SUPABASE_MONTHLY_ESTIMATE=45.00
METALPRICEAPI_MONTHLY_ESTIMATE=0
OPENAI_MONTHLY_ESTIMATE=2.00
GEMINI_MONTHLY_ESTIMATE=8.00
# Anthropic is manual until the plan upgrades to Teams/Enterprise (Admin API gated).
ANTHROPIC_MONTHLY_ESTIMATE=8.00
# Vercel/Railway are manual while on Hobby plan (no programmatic usage API).
# See sources/vercel-api.js.disabled and railway-api.js.disabled for the API
# implementations that should be restored after a plan upgrade.
VERCEL_MONTHLY_ESTIMATE=0.00
RAILWAY_MONTHLY_ESTIMATE=5.00
